{
  "schema_name": "K-Volley Lab Country Master Schema",
  "schema_version": "v1",
  "description": "K-Volley Lab에서 국가 정보를 하나의 country_id로 관리하기 위한 표준 스키마. 선수, 학교, 팀, 대회, 경기 데이터가 모두 country_id를 참조한다.",
  "principles": [
    "country_id는 절대 변경하지 않는다.",
    "국가명, 영문명, 국기 코드가 변경되어도 country_id는 유지한다.",
    "선수, 학교, 팀, 대회는 국가명을 직접 저장하지 않고 country_id를 참조한다.",
    "ISO, IOC, FIVB 코드를 함께 저장해 국제대회 데이터와 연결한다.",
    "국기, 대륙, 시간대 등 확장 정보를 관리한다."
  ],
  "id_policy": {
    "country_id": {
      "format": "KVL-CTY-000001",
      "meaning": "K-Volley Lab Country unique ID",
      "rule": "순번 기반 내부 고유 ID. 국가명, 표기법, 코드가 바뀌어도 변경하지 않는다."
    },
    "short_code": {
      "format": "KOR",
      "meaning": "사람이 보기 쉬운 국가 코드",
      "rule": "ISO3 또는 FIVB 코드를 우선 사용한다. 기본키로 사용하지 않는다."
    }
  },
  "fields": {
    "system": {
      "country_id": "string, required",
      "short_code": "string, optional",
      "created_at": "YYYY-MM-DD",
      "updated_at": "YYYY-MM-DD",
      "status": "active | inactive | unknown",
      "data_confidence": "confirmed | partial | sample | needs_review"
    },
    "identity": {
      "name_ko": "string, required",
      "name_en": "string, required",
      "official_name": "string",
      "continent": "Asia | Europe | North America | South America | Africa | Oceania | Unknown"
    },
    "codes": {
      "iso2": "string",
      "iso3": "string",
      "ioc_code": "string",
      "fivb_code": "string",
      "flag_code": "string"
    },
    "volleyball": {
      "confederation": "AVC | CEV | NORCECA | CSV | CAVB | Unknown",
      "fivb_member": "true | false | unknown"
    },
    "meta": {
      "timezone": "string",
      "language": "string",
      "currency": "string"
    },
    "links": {
      "fivb_page": "url",
      "volleyball_world_page": "url",
      "federation_website": "url"
    },
    "source_ids": [
      "source_id list"
    ]
  },
  "related_files": [
    "player_master.json",
    "school_master.json",
    "team_master.json",
    "competition_master.json",
    "match_master.json",
    "source_master.json"
  ]
}