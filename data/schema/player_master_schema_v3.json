{
  "schema_name": "K-Volley Lab Player Master Schema",
  "schema_version": "v3",
  "description": "K-Volley Lab 전체 선수 통합 마스터 스키마. 국내 선수, 국제 선수, 국가대표, 프로, 대학, 유소년 선수를 하나의 player_id로 관리한다.",
  "principles": [
    "player_id는 절대 변경하지 않는다.",
    "display_code는 사람이 보기 쉬운 보조 코드이며, 기본키로 사용하지 않는다.",
    "국내/국제 선수는 분리하지 않고 category로 구분한다.",
    "대회 로스터, 성장 이력, 기록, 기사, 영상은 모두 player_id를 참조한다.",
    "공개 자료 기반 데이터만 저장하며 모든 핵심 데이터는 source_id와 연결한다."
  ],
  "id_policy": {
    "player_id": {
      "format": "KVL-P-000001",
      "meaning": "K-Volley Lab Player unique ID",
      "rule": "순번 기반 내부 고유 ID. 이름, 생년월일, 소속이 바뀌어도 변경하지 않는다."
    },
    "display_code": {
      "format": "KMJ-051029",
      "meaning": "사람이 보기 쉬운 표시용 코드",
      "rule": "영문 이니셜 + 생년월일 후보. 동명이인/개명/생년월일 비공개 문제로 기본키로 사용하지 않는다."
    }
  },
  "fields": {
    "system": {
      "player_id": "string, required",
      "display_code": "string, optional",
      "created_at": "YYYY-MM-DD",
      "updated_at": "YYYY-MM-DD",
      "status": "active | retired | unknown | duplicate_review",
      "data_confidence": "confirmed | partial | sample | needs_review"
    },
    "identity": {
      "name_ko": "string",
      "name_en": "string",
      "name_native": "string",
      "gender": "M | F",
      "nationality": "ISO-3 or country code",
      "birth_date": "YYYY-MM-DD or empty",
      "birth_year": "number or empty",
      "birth_place": "string",
      "hand": "Right | Left | Unknown"
    },
    "classification": {
      "category": "Domestic | International | Both | Unknown",
      "current_level": "초등 | 중등 | 고등 | 대학 | 실업 | 프로 | 국가대표 | 해외 | Unknown",
      "current_team_id": "team_master reference",
      "current_team_name": "string",
      "primary_position": "OH | OP | MB | S | L | DS | Unknown",
      "sub_position": "string"
    },
    "physical": {
      "height_cm": "number",
      "weight_kg": "number",
      "spike_cm": "number",
      "block_cm": "number"
    },
    "links": {
      "volleybox": "url",
      "fivb_profile": "url",
      "kovo_profile": "url",
      "instagram": "url",
      "youtube": "url",
      "photo": "path or url"
    },
    "source_ids": [
      "source_id list"
    ]
  },
  "related_files": [
    "growth_history.json",
    "domestic_players.json",
    "international_rosters.json",
    "competition_master.json",
    "team_master.json",
    "school_master.json",
    "sources.json"
  ]
}